#!/usr/bin/env bash
# Launcher for the Nagini MCP server.
# Resolution order:
#   1. $NAGINI_MCP        — explicit path to a nagini_mcp executable
#   2. $VIRTUAL_ENV       — the active virtualenv
#   3. $CLAUDE_PROJECT_DIR/{.venv,venv} — a virtualenv at the project root
#   4. nagini_mcp on PATH
#   5. python3 -m nagini_translation.mcp_server

set -u

fail() {
  printf '%s\n' \
    "nagini-mcp: $1" \
    "" \
    "The Nagini plugin requires:" \
    "  * Python 3 with a nagini version that includes the MCP server:" \
    "      python3 -m pip install --upgrade \"nagini[mcp]\"" \
    "  * A 64-bit Java runtime (JDK/JRE 11+) for the Viper backend:  https://adoptium.net" \
    "" \
    "If nagini lives in a virtualenv the launcher does not detect, point it there:" \
    "  export NAGINI_MCP=/path/to/venv/bin/nagini_mcp" \
    "" \
    "More help: https://github.com/viperproject/nagini-claude-plugin" >&2
  exit 1
}

if ! command -v java >/dev/null 2>&1 && [ -z "${JAVA_HOME:-}" ]; then
  fail "no Java runtime found (neither 'java' on PATH nor JAVA_HOME set); the Viper backend needs one"
fi

if [ -n "${NAGINI_MCP:-}" ]; then
  [ -x "$NAGINI_MCP" ] || fail "NAGINI_MCP is set to '$NAGINI_MCP', which is not an executable file"
  exec "$NAGINI_MCP" "$@"
fi

# Prefer virtualenvs over a global install: the active venv first, then a
# venv at the project root.
for venv in "${VIRTUAL_ENV:-}" "${CLAUDE_PROJECT_DIR:-}/.venv" "${CLAUDE_PROJECT_DIR:-}/venv"; do
  if [ -x "$venv/bin/nagini_mcp" ]; then
    exec "$venv/bin/nagini_mcp" "$@"
  fi
done

if command -v nagini_mcp >/dev/null 2>&1; then
  exec nagini_mcp "$@"
fi

if command -v python3 >/dev/null 2>&1 && python3 -c 'import nagini_translation.mcp_server' >/dev/null 2>&1; then
  exec python3 -m nagini_translation.mcp_server "$@"
fi

fail "could not find the Nagini MCP server; nagini may be missing, too old, or in an undetected virtualenv"
