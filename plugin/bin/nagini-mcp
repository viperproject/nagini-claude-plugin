#!/usr/bin/env bash
# Launcher for the Nagini MCP server. Runs a pinned nagini release via uvx,
# isolated from any Python environment on the machine.
#   1. $NAGINI_MCP — explicit path to a nagini_mcp executable (e.g. a source build)
#   2. uvx --python $NAGINI_PYTHON --from "nagini[mcp]==$NAGINI_VERSION" nagini_mcp

set -u

# Single source of truth for the provisioned toolchain (docker/Dockerfile
# parses these defaults; the docs reference this file). Both env-overridable.
NAGINI_VERSION="${NAGINI_VERSION:-1.3.1}"
NAGINI_PYTHON="${NAGINI_PYTHON:-3.12}"

fail() {
  printf '%s\n' \
    "nagini-mcp: $1" \
    "" \
    "The Nagini plugin requires:" \
    "  * uv, which provisions nagini $NAGINI_VERSION automatically on first start:" \
    "      curl -LsSf https://astral.sh/uv/install.sh | sh" \
    "  * A 64-bit Java runtime (JDK/JRE 11+) for the Viper backend:  https://adoptium.net" \
    "" \
    "To use your own nagini instead (e.g. a source build):" \
    "  export NAGINI_MCP=/path/to/venv/bin/nagini_mcp" \
    "" \
    "More help: https://github.com/viperproject/nagini-claude-plugin" >&2
  exit 1
}

if ! command -v java >/dev/null 2>&1 && [ -z "${JAVA_HOME:-}" ]; then
  fail "no Java runtime found (neither 'java' on PATH nor JAVA_HOME set); the Viper backend needs one"
fi

if [ -n "${NAGINI_MCP:-}" ]; then
  [ -x "$NAGINI_MCP" ] || fail "NAGINI_MCP is set to '$NAGINI_MCP', which is not an executable file"
  exec "$NAGINI_MCP" "$@"
fi

command -v uvx >/dev/null 2>&1 || fail "uvx not found; the launcher provisions nagini through uv"

exec uvx --python "${NAGINI_PYTHON}" --from "nagini[mcp]==${NAGINI_VERSION}" nagini_mcp "$@"
